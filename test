fields @timestamp, eventName, userIdentity.type, userIdentity.arn, sourceIPAddress, awsRegion
| filter eventSource = "monitoring.amazonaws.com"
| filter eventName in [
    "PutMetricAlarm",
    "PutCompositeAlarm",
    "DeleteAlarms",
    "DisableAlarmActions",
    "EnableAlarmActions",
    "SetAlarmState"
]
| stats count(*) as changes by bin(5m), eventName, userIdentity.type, userIdentity.arn, sourceIPAddress, awsRegion
| sort changes desc
